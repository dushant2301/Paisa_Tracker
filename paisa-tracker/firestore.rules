rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── User profiles ──────────────────────────────────────────────────────────
    // Each user can only read/write their own document.
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;

      // ── Expenses ──────────────────────────────────────────────────────────
      match /expenses/{expenseId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }

      // ── Shop Expenses ──────────────────────────────────────────────────────
      match /shopExpenses/{shopId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }

      // ── Friend Transactions ────────────────────────────────────────────────
      match /friendTransactions/{txId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }

      // ── Report History ────────────────────────────────────────────────────
      match /reportHistory/{reportId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
    }

    // ── Deny ALL other documents ────────────────────────────────────────────
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
