rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── TEMPORARY TEST MODE — allows authenticated users to read/write everything ──
    // This is intentionally open to debug the connection issue.
    // Once data is confirmed working, switch back to strict rules.
    match /{document=**} {
      allow read, write: if request.auth != null;
    }
  }
}
